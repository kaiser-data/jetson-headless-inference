[Unit]
Description=Jetson AI — Piper TTS Service (port 5500)
After=network.target pulseaudio.service sound.target
Wants=pulseaudio.service

[Service]
Type=simple
WorkingDirectory=%h/gamma4_models
ExecStart=/usr/bin/python3 %h/gamma4_models/voice/piper-service.py
Restart=on-failure
RestartSec=5
StandardOutput=append:%h/.local/share/jetson-ai/piper.log
StandardError=append:%h/.local/share/jetson-ai/piper.log

[Install]
WantedBy=default.target
