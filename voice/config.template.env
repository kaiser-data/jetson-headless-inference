# Jetson AI — voice pipeline environment overrides
# Copy to .voice_env in the repo root and fill in your credentials.
# This file is sourced by all jetson-* systemd services (EnvironmentFile=-...).

# ── LLM settings ──────────────────────────────────────────────────────────────
VOICE_MODE=local              # local | openai | anthropic
VOICE_OUTPUT=stream           # stream | speaker | both
# 0.8b (~37 tok/s) is the realtime-conversation default; qwen3.5:4b
# (~14 tok/s — below comfortable speech rate) stays available per-request
# for quality tasks.
OLLAMA_MODEL=qwen3.5:0.8b

# ── Realtime latency tuning ───────────────────────────────────────────────────
# Measured on the Orin Nano 8GB, 2026-07: voice-to-first-audio is dominated
# by STT (whisper small on CPU: ~6.7 s for 3.4 s audio) and by the first
# sentence's TTS (ryan-HIGH ~1.5 s vs lessac-MEDIUM ~0.3 s).
# WHISPER_MODEL=small         # small | base (2x faster, small quality loss)
# WHISPER_DEVICE=cpu          # cuda needs ~1 GB GPU — fine alongside a ≤1B LLM
# WHISPER_COMPUTE=int8        # use int8_float16 with cuda
# WHISPER_IDLE_S=0            # 0 = keep whisper resident (assistant mode);
#                             # default 900 unloads after 15 min (saves ~1 GB)
# FIRST_CHUNK_CHARS=60        # cut the first reply chunk early at a clause
#                             # boundary; 0 disables
# Voice quality vs speed: the "en" alias maps to en_US-ryan-high (~5x slower
# to synthesize than a -medium voice). For lowest latency request
# voice=en_female (lessac-medium) or download ryan-medium.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=sk-ant-...

# ── API auth (recommended if cloud API keys are set above) ───────────────────
# If set, pipeline (8000) and control API (8080) require the header:
#   Authorization: Bearer <token>
# on every endpoint except /health. Generate one: openssl rand -hex 24
# VOICE_API_TOKEN=

# ── Audio routing ──────────────────────────────────────────────────────────────
# PULSE_SINK=                 # leave blank for system default
BT_SPEAKER_MAC=88:88:11:07:10:5C
BT_SPEAKER_NAME=Boomcore P06

# ── Google Calendar (preferred) ───────────────────────────────────────────────
# Setup (one time):
#   1. pip install google-auth google-auth-oauthlib google-api-python-client
#   2. Create OAuth credentials at https://console.cloud.google.com/
#      APIs & Services → Credentials → Create → OAuth client ID → Desktop app
#      Download JSON → save as .google_credentials.json in the repo root
#   3. python3 voice/setup-google-auth.py
#      Opens a URL — paste in any browser and log in with your Google account
#      Token saved to ~/.local/share/jetson-ai/google_token.json
#
# Optional overrides (defaults shown):
# GOOGLE_TOKEN_FILE=~/.local/share/jetson-ai/google_token.json
# GOOGLE_CALENDAR_ID=primary  # or a specific calendar ID
# CALDAV_DAYS=30              # how many days ahead to cache

# ── CalDAV fallback (used only if Google token is absent) ────────────────────
# CALDAV_URL=https://cloud.example.com/remote.php/dav/principals/users/you/
# CALDAV_USER=you@example.com
# CALDAV_PASS=your-app-password

# ── IMAP (email sync) ─────────────────────────────────────────────────────────
# Gmail: enable IMAP in Settings → See all settings → Forwarding and POP/IMAP
#        Use an App Password (Google Account → Security → App Passwords)
#        if 2FA is on (it almost certainly is).
# IMAP_HOST=imap.gmail.com
# IMAP_USER=you@gmail.com
# IMAP_PASS=your-16-char-app-password
# IMAP_PORT=993               # default 993 (IMAP over TLS)
# EMAIL_LIMIT=30              # how many recent messages to cache (default 30)
#
# Important sender addresses/domains — these are always marked high importance:
# KNOWN_SENDERS=boss@company.com,investor@firm.com,yourdomain.com
